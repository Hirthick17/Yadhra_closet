# =============================================================================
# Yadhra Closet — Frontend Environment Variables (PRODUCTION)
# Copy this file to .env.production and fill in your Render backend URL.
# Vercel reads .env.production during build (vercel deploy).
# =============================================================================

# Your Render backend URL — copy from Render dashboard after deployment
# Format: https://yadhra-closet-api.onrender.com/api
VITE_API_URL=https://your-render-app.onrender.com/api
