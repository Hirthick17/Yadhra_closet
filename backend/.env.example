# =============================================================================
# Yadhra Closet — Backend Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git — only commit .env.example
# =============================================================================

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development          # Change to 'production' on Render

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Development:  mongodb://localhost:27017/yadhra_closet
# Production:   Get from MongoDB Atlas → Connect → Drivers
#               Format: mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/yadhra_closet
MONGODB_URI=mongodb://localhost:27017/yadhra_closet

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=your_refresh_secret_here
REFRESH_TOKEN_EXPIRES_IN=7d

# ── Frontend URL (for CORS) ───────────────────────────────────────────────────
# Development:  http://localhost:8080
# Production:   https://your-app.vercel.app  (exact URL from Vercel dashboard)
CLIENT_URL=http://localhost:8080

# ── Cloudinary (free image hosting) ──────────────────────────────────────────
# Sign up at https://cloudinary.com (free tier: 25GB storage, 25GB bandwidth)
# Dashboard → API Keys → Copy these values
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
